{
  "name": "maroctax",
  "version": "1.0.0",
  "description": "Moroccan payroll calculation library — IR, CNSS, AMO, and more",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "morocco",
    "payroll",
    "salary",
    "cnss",
    "amo",
    "ir",
    "tax",
    "maroctax"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Hamza-spc/maroctax.git",
    "directory": "typescript/maroctax"
  },
  "homepage": "https://github.com/Hamza-spc/maroctax#readme",
  "bugs": {
    "url": "https://github.com/Hamza-spc/maroctax/issues"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:step": "npm test",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  }
}
